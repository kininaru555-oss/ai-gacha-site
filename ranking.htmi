<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>AIガチャ 人気ランキング</title>

<style>

body{
font-family:sans-serif;
background:#111;
color:white;
text-align:center;
margin:0;
padding:20px;
}

h1{
margin-bottom:30px;
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:20px;
max-width:1000px;
margin:auto;
}

.card{
background:#222;
padding:15px;
border-radius:12px;
}

img,video{
width:100%;
border-radius:10px;
}

button{
margin-top:10px;
padding:8px 14px;
border:none;
border-radius:8px;
background:#e91e63;
color:white;
cursor:pointer;
}

.likes{
margin-top:8px;
color:#ffcc66;
font-size:14px;
}

.toplink{
display:inline-block;
margin-bottom:20px;
color:#fff;
text-decoration:none;
background:#444;
padding:8px 14px;
border-radius:8px;
}

</style>
</head>

<body>

<a class="toplink" href="index.html">← ガチャに戻る</a>

<h1>人気ランキング</h1>

<div id="ranking" class="grid"></div>

<script>

async function loadRanking(){

const res = await fetch("data.json");
const data = await res.json();

let items = data.map((item,i)=>{

let likes = localStorage.getItem("like_"+i) || 0;

return {
...item,
likes:parseInt(likes),
index:i
}

})

items.sort((a,b)=>b.likes-a.likes)

const rankingDiv = document.getElementById("ranking");

items.forEach(item=>{

let media="";

if(item.type==="video"){
media=`<video src="${item.file}" controls></video>`
}else{
media=`<img src="${item.file}">`
}

const card=document.createElement("div");

card.className="card";

card.innerHTML=`

<h3>${item.title}</h3>

${media}

<div>作者: ${item.creator}</div>

<div class="likes">❤️ ${item.likes}</div>

<button onclick="like(${item.index})">いいね</button>

`

rankingDiv.appendChild(card)

})

}

function like(i){

let count = localStorage.getItem("like_"+i) || 0;

count++;

localStorage.setItem("like_"+i,count);

location.reload();

}

loadRanking()

</script>

</body>
</html>
